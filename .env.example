# ============================================================
# WebISO v2 — Variables de entorno
# ============================================================
# Copia este archivo a .env y completa los valores reales.
# NUNCA incluyas .env en control de versiones.
# ============================================================

# ── Flask ────────────────────────────────────────────────────
# Clave secreta para firmar sesiones Flask. Usar valor aleatorio largo.
# Ejemplo: python3 -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=cambia_esto_por_un_valor_aleatorio_seguro

# Modo de Flask: 'production' o 'development'
FLASK_ENV=production

# ── SMTP — Envío de correo ───────────────────────────────────
# Servidor SMTP (por defecto: smtp.gmail.com)
SMTP_SERVER=smtp.gmail.com

# Puerto SMTP con STARTTLS (por defecto: 587)
SMTP_PORT=587

# Dirección de correo remitente
SMTP_USER=tu_correo@dominio.com

# Contraseña o App Password del remitente (no usar la contraseña principal)
SMTP_PASSWORD=app_password_aqui

# ── Despliegue — Scripts de deploy y rsync ───────────────────
# IP o hostname del servidor de producción
DEPLOY_HOST=10.11.121.58

# Usuario SSH en el servidor
DEPLOY_USER=marco

# Puerto SSH (por defecto: 22)
DEPLOY_PORT=22

# Ruta de destino del frontend compilado (dist/) en el servidor
DEPLOY_PATH=/var/www/webiso

# Directorio local del build (relativo a la raíz del proyecto)
SOURCE_BUILD_DIR=dist

# Directorio del proyecto en el servidor (para actualizaciones del backend)
SOURCE_PROJECT_DIR=/home/marco/webiso

# Nombre del sitio Nginx
NGINX_SITE_NAME=webiso

# Ruta al archivo de configuración Nginx fuente
NGINX_SITE_SOURCE=debian_deployment/nginx.conf

# ── URLs públicas del ecosistema ERP ─────────────────────────
# URL base pública de WebISO (sin slash final)
PUBLIC_BASE_URL=http://10.11.121.58:8081

# URL base del CRM DataCom (autenticación SSO)
ERP_AUTH_BASE_URL=http://10.11.121.58

# URL base del CRM
CRM_BASE_URL=http://10.11.121.58

# URL de DAIA
DAIA_BASE_URL=http://10.11.121.58:8005

# URL del sistema de Prospección
PROSPECCION_BASE_URL=http://10.11.121.58:8080

# URL del sistema de Acta de Reuniones
ACTA_BASE_URL=http://10.11.121.58:8030

# ── Respaldos ────────────────────────────────────────────────
# Directorio raíz donde se guardan los respaldos
BACKUP_ROOT=/var/backups/datacom

# Ruta a uploads.db (dejar vacío para usar la ruta por defecto del proyecto)
SQLITE_DB_PATH=

# Ruta al directorio de archivos subidos
MEDIA_PATH=

# Rutas adicionales a incluir en el respaldo (separadas por coma)
ADDITIONAL_ARCHIVE_PATHS=

# ── Versiones de herramientas ────────────────────────────────
# Versión mayor de Node.js a instalar en el servidor
NODE_MAJOR_VERSION=20

# Ejecutable de Python en el servidor
PYTHON_BIN=python3

